diff --git a/common/process/ebpf/socket_monitor.c b/common/process/ebpf/socket_monitor.c
new file mode 100644
index 00000000..cfe7dfb9
--- /dev/null
+++ b/common/process/ebpf/socket_monitor.c
@@ -0,0 +1,164 @@
+//go:build ignore
+
+// eBPF program to track socket→process mappings.
+// Uses fentry/fexit trampolines (kernel 5.5+) with CO-RE for portable field access.
+// Field offsets are resolved at load time via BTF — exact struct layout is not required.
+
+#include <linux/bpf.h>
+#include <linux/errno.h>
+#include <linux/types.h>
+#include <bpf/bpf_helpers.h>
+#include <bpf/bpf_tracing.h>
+#include <bpf/bpf_core_read.h>
+
+char __license[] SEC("license") = "Dual MIT/GPL";
+
+#define AF_INET 2
+#define AF_INET6 10
+#define IPPROTO_TCP 6
+#define IPPROTO_UDP 17
+
+// Kernel struct definitions with CO-RE support.
+// Only fields we access need to be declared; offsets are resolved via BTF.
+
+struct in6_addr {
+	__u8 in6_u[16];
+} __attribute__((preserve_access_index));
+
+struct sock_common {
+	union {
+		struct {
+			__be32 skc_daddr;
+			__be32 skc_rcv_saddr;
+		};
+	};
+	union {
+		struct {
+			__be16 skc_dport;
+			__u16 skc_num;
+		};
+	};
+	short unsigned int skc_family;
+	struct in6_addr skc_v6_rcv_saddr;
+} __attribute__((preserve_access_index));
+
+struct sock {
+	struct sock_common __sk_common;
+} __attribute__((preserve_access_index));
+
+struct msghdr;
+struct sockaddr;
+
+// Map key: identifies a local socket endpoint
+struct socket_key {
+	__u8 addr[16];
+	__u16 port;       // Source port (host byte order)
+	__u8 protocol;
+	__u8 padding;
+};
+
+// Map value: process info
+struct socket_info {
+	__u32 pid;
+	__u32 uid;
+};
+
+struct {
+	__uint(type, BPF_MAP_TYPE_LRU_HASH);
+	__uint(max_entries, 65536);
+	__type(key, struct socket_key);
+	__type(value, struct socket_info);
+} socket_pid_map SEC(".maps");
+
+static __always_inline void store_ipv4_socket(struct sock *sk, __u8 protocol)
+{
+	struct socket_key key = {};
+	struct socket_info info = {};
+
+	__u16 sport = sk->__sk_common.skc_num;
+	if (sport == 0)
+		return;
+
+	// Store raw __be32 bytes as the kernel stores them
+	*((__be32 *)key.addr) = sk->__sk_common.skc_rcv_saddr;
+	key.port = sport;
+	key.protocol = protocol;
+
+	__u64 pid_tgid = bpf_get_current_pid_tgid();
+	__u64 uid_gid = bpf_get_current_uid_gid();
+	info.pid = pid_tgid >> 32;
+	info.uid = uid_gid & 0xFFFFFFFF;
+
+	bpf_map_update_elem(&socket_pid_map, &key, &info, BPF_ANY);
+}
+
+static __always_inline void store_ipv6_socket(struct sock *sk, __u8 protocol)
+{
+	if (!bpf_core_field_exists(sk->__sk_common.skc_v6_rcv_saddr))
+		return;
+
+	struct socket_key key = {};
+	struct socket_info info = {};
+
+	__u16 sport = sk->__sk_common.skc_num;
+	if (sport == 0)
+		return;
+
+	struct in6_addr saddr = sk->__sk_common.skc_v6_rcv_saddr;
+	__builtin_memcpy(key.addr, &saddr, sizeof(saddr));
+	key.port = sport;
+	key.protocol = protocol;
+
+	__u64 pid_tgid = bpf_get_current_pid_tgid();
+	__u64 uid_gid = bpf_get_current_uid_gid();
+	info.pid = pid_tgid >> 32;
+	info.uid = uid_gid & 0xFFFFFFFF;
+
+	bpf_map_update_elem(&socket_pid_map, &key, &info, BPF_ANY);
+}
+
+// --- TCP ---
+
+SEC("fexit/tcp_v4_connect")
+int BPF_PROG(fexit_tcp_v4_connect, struct sock *sk, struct sockaddr *uaddr, int addr_len, int ret)
+{
+	if (sk->__sk_common.skc_family != AF_INET)
+		return 0;
+	if (ret != 0 && ret != -EINPROGRESS)
+		return 0;
+	store_ipv4_socket(sk, IPPROTO_TCP);
+	return 0;
+}
+
+SEC("fexit/tcp_v6_connect")
+int BPF_PROG(fexit_tcp_v6_connect, struct sock *sk, struct sockaddr *uaddr, int addr_len, int ret)
+{
+	if (ret != 0 && ret != -EINPROGRESS)
+		return 0;
+	if (sk->__sk_common.skc_family == AF_INET)
+		store_ipv4_socket(sk, IPPROTO_TCP);
+	else if (sk->__sk_common.skc_family == AF_INET6)
+		store_ipv6_socket(sk, IPPROTO_TCP);
+	return 0;
+}
+
+// --- UDP ---
+
+SEC("fentry/udp_sendmsg")
+int BPF_PROG(fentry_udp_sendmsg, struct sock *sk, struct msghdr *msg, __u64 len)
+{
+	if (sk->__sk_common.skc_family != AF_INET)
+		return 0;
+	store_ipv4_socket(sk, IPPROTO_UDP);
+	return 0;
+}
+
+SEC("fentry/udpv6_sendmsg")
+int BPF_PROG(fentry_udpv6_sendmsg, struct sock *sk, struct msghdr *msg, __u64 len)
+{
+	if (sk->__sk_common.skc_family == AF_INET)
+		store_ipv4_socket(sk, IPPROTO_UDP);
+	else if (sk->__sk_common.skc_family == AF_INET6)
+		store_ipv6_socket(sk, IPPROTO_UDP);
+	return 0;
+}
