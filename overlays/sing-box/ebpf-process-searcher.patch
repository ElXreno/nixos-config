diff --git a/common/process/searcher_ebpf_linux.go b/common/process/searcher_ebpf_linux.go
new file mode 100644
index 00000000..b5fa237e
--- /dev/null
+++ b/common/process/searcher_ebpf_linux.go
@@ -0,0 +1,190 @@
+//go:build linux && !android
+
+package process
+
+//go:generate clang -target bpfel -O2 -g -Wall -c ebpf/socket_monitor.c -o ebpf/socket_monitor_bpfel.o
+
+import (
+	"bytes"
+	"context"
+	_ "embed"
+	"net/netip"
+	"os"
+	"strconv"
+	"syscall"
+	"time"
+
+	"github.com/sagernet/sing-box/adapter"
+	"github.com/sagernet/sing-box/log"
+	"github.com/sagernet/sing/common"
+	E "github.com/sagernet/sing/common/exceptions"
+	N "github.com/sagernet/sing/common/network"
+	"github.com/sagernet/sing/contrab/freelru"
+	"github.com/sagernet/sing/contrab/maphash"
+
+	"github.com/cilium/ebpf"
+	"github.com/cilium/ebpf/link"
+	"github.com/cilium/ebpf/rlimit"
+)
+
+//go:embed ebpf/socket_monitor_bpfel.o
+var bpfBytecode []byte
+
+// Must match struct socket_key in socket_monitor.c exactly
+type bpfSocketKey struct {
+	Addr     [16]byte
+	Port     uint16
+	Protocol uint8
+	Padding  uint8
+}
+
+// Must match struct socket_info in socket_monitor.c exactly
+type bpfSocketInfo struct {
+	PID uint32
+	UID uint32
+}
+
+var _ Searcher = (*ebpfSearcher)(nil)
+
+type ebpfSearcher struct {
+	logger     log.ContextLogger
+	collection *ebpf.Collection
+	links      []link.Link
+	pidMap     *ebpf.Map
+	pathCache  freelru.Cache[uint32, string]
+}
+
+const pathCacheTTL = 5 * time.Second
+
+func newEBPFSearcher(logger log.ContextLogger) (*ebpfSearcher, error) {
+	if err := rlimit.RemoveMemlock(); err != nil {
+		return nil, E.Cause(err, "remove memlock")
+	}
+
+	spec, err := ebpf.LoadCollectionSpecFromReader(bytes.NewReader(bpfBytecode))
+	if err != nil {
+		return nil, E.Cause(err, "load BPF spec")
+	}
+
+	coll, err := ebpf.NewCollection(spec)
+	if err != nil {
+		return nil, E.Cause(err, "create BPF collection")
+	}
+
+	s := &ebpfSearcher{
+		logger:     logger,
+		collection: coll,
+		pidMap:     coll.Maps["socket_pid_map"],
+		pathCache:  common.Must1(freelru.NewSharded[uint32, string](1024, maphash.NewHasher[uint32]().Hash32)),
+	}
+
+	if s.pidMap == nil {
+		coll.Close()
+		return nil, E.New("socket_pid_map not found in BPF collection")
+	}
+
+	// Attach fentry/fexit programs via BTF trampoline
+	required := []string{
+		"fexit_tcp_v4_connect",
+		"fentry_udp_sendmsg",
+	}
+
+	for _, name := range required {
+		prog := coll.Programs[name]
+		if prog == nil {
+			s.Close()
+			return nil, E.New("BPF program ", name, " not found")
+		}
+		l, err := link.AttachTracing(link.TracingOptions{Program: prog})
+		if err != nil {
+			s.Close()
+			return nil, E.Cause(err, "attach ", name)
+		}
+		s.links = append(s.links, l)
+	}
+
+	// Optional: IPv6 programs
+	optional := []string{
+		"fexit_tcp_v6_connect",
+		"fentry_udpv6_sendmsg",
+	}
+
+	for _, name := range optional {
+		prog := coll.Programs[name]
+		if prog == nil {
+			continue
+		}
+		l, err := link.AttachTracing(link.TracingOptions{Program: prog})
+		if err != nil {
+			logger.Debug("optional BPF attach ", name, ": ", err)
+			continue
+		}
+		s.links = append(s.links, l)
+	}
+
+	return s, nil
+}
+
+func (s *ebpfSearcher) FindProcessInfo(ctx context.Context, network string, source netip.AddrPort, destination netip.AddrPort) (*adapter.ConnectionOwner, error) {
+	var key bpfSocketKey
+
+	addr := source.Addr().Unmap()
+	if addr.Is4() {
+		a4 := addr.As4()
+		copy(key.Addr[:4], a4[:])
+	} else {
+		a16 := addr.As16()
+		copy(key.Addr[:], a16[:])
+	}
+	key.Port = source.Port()
+
+	switch network {
+	case N.NetworkTCP:
+		key.Protocol = syscall.IPPROTO_TCP
+	case N.NetworkUDP:
+		key.Protocol = syscall.IPPROTO_UDP
+	default:
+		return nil, os.ErrInvalid
+	}
+
+	var info bpfSocketInfo
+	err := s.pidMap.Lookup(&key, &info)
+	if err != nil {
+		return nil, err
+	}
+
+	processPath := s.getProcessPath(info.PID)
+
+	return &adapter.ConnectionOwner{
+		ProcessID:   info.PID,
+		UserId:      int32(info.UID),
+		ProcessPath: processPath,
+	}, nil
+}
+
+func (s *ebpfSearcher) getProcessPath(pid uint32) string {
+	if p, ok := s.pathCache.Get(pid); ok {
+		return p
+	}
+
+	p, err := os.Readlink(pathProc + "/" + strconv.FormatUint(uint64(pid), 10) + "/exe")
+	if err != nil {
+		return ""
+	}
+
+	s.pathCache.AddWithLifetime(pid, p, pathCacheTTL)
+	return p
+}
+
+func (s *ebpfSearcher) Close() error {
+	var err error
+	for _, l := range s.links {
+		err = E.Append(err, l.Close(), func(closeErr error) error {
+			return E.Cause(closeErr, "close BPF link")
+		})
+	}
+	if s.collection != nil {
+		s.collection.Close()
+	}
+	return err
+}
